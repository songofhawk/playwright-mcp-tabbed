# Copy to local.env in this same directory (next to resolve-base-url.js).
# Add local.env to your project or global .gitignore if you put secrets here.
#
# resolve-base-url.js reads PLAYWRIGHT_BASE_URL only (not BASE_URL), in this order:
#   1) environment variable PLAYWRIGHT_BASE_URL
#   2) at each detected git repo root: .env.local, .env, playwright.env.local
#   3) ./local.env (this scripts folder)
#
# Git roots: walk up from cwd, then from skill install path (see script header).

PLAYWRIGHT_BASE_URL=http://localhost:3000
